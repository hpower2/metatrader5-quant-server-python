# MT5 container
CUSTOM_USER=admin
PASSWORD=change-me
MT5_API_PORT=5001
VNC_DOMAIN=vnc-mt5.example.com
API_DOMAIN=api-mt5.example.com

# Traefik
TRAEFIK_DOMAIN=traefik.example.com
TRAEFIK_USERNAME=admin
TRAEFIK_HASHED_PASSWORD=replace-with-apr1-hash
ACME_EMAIL=ops@example.com
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Shared bind-mount root for persistent compose data
SHARED_VOLUME_ROOT=/mnt/shared/mt5

# Monitoring
GRAFANA_DOMAIN=grafana.example.com

# Django
DJANGO_DOMAIN=django.example.com

# Database
POSTGRES_DB=postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://admin:change-me@postgres:5432/postgres

# Existing MT5 HTTP API
MT5_API_URL=http://mt5:5001
MT5_API_BASE_URL=http://mt5:5001
MT5_API_AUTH_HEADER=

# Quant API / worker
QUANT_API_DOMAIN=quant.example.com
QUANT_API_URL=http://quant-api:8010
WEB_DOMAIN=quant-console.example.com
DEFAULT_SYMBOLS=EURUSD,GBPUSD,USDJPY
DEFAULT_TIMEFRAMES=M1,M5,M15
SYMBOL_VISIBLE_ONLY=true
INCREMENTAL_SYNC_NUM_BARS=500
HISTORICAL_BACKFILL_CHUNK_MINUTES=1440
WORKER_SYNC_INTERVAL_SECONDS=300
WORKER_BOOTSTRAP_ON_START=true
WORKER_INCREMENTAL_ON_START=true
PAPER_INITIAL_CASH=100000
